<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JobDeck | Dashboard</title>
    <link rel="icon" href="/logoImage/logo-2.png" />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-50 flex min-h-screen items-center justify-center p-4 font-sans">
    
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl border border-gray-100 p-8 space-y-6">
      
      <div class="flex flex-col items-center text-center space-y-2">
        <div class="h-12 w-12 bg-blue-100 rounded-full flex items-center justify-center mb-1">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-blue-600">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 tracking-tight">
          Dashboard
        </h1>
        <p class="text-sm text-gray-500">
          Welcome to your account
        </p>
      </div>

      <% if (typeof success !== 'undefined' && success.length > 0) { %>
        <div id="success-alert" class="flex items-center p-4 text-sm text-green-800 border border-green-200 rounded-lg bg-green-50 transition-opacity duration-500" role="alert">
          <svg class="flex-shrink-0 inline w-5 h-5 me-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z"/>
          </svg>
          <div>
            <span class="font-medium">Success!</span> <%= success[0] %>
          </div>
        </div>
      <% } %>

      <% if (typeof error !== 'undefined' && error.length > 0) { %>
        <div id="error-alert" class="flex items-center p-4 text-sm text-red-800 border border-red-200 rounded-lg bg-red-50 transition-opacity duration-500" role="alert">
          <svg class="flex-shrink-0 inline w-5 h-5 me-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM10 15a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm1-4a1 1 0 0 1-2 0V6a1 1 0 0 1 2 0v5Z"/>
          </svg>
          <div>
            <span class="font-medium">Oops!</span> <%= error[0] %>
          </div>
        </div>
      <% } %>

      <div class="bg-gray-50 p-5 rounded-xl border border-gray-200 space-y-4">
        <div class="flex justify-between items-center border-b border-gray-200 pb-3">
          <span class="text-sm font-medium text-gray-500">First Name</span>
          <span class="text-sm font-semibold text-gray-900"><%= user.firstName %></span>
        </div>
        
        <div class="flex justify-between items-center border-b border-gray-200 pb-3">
          <span class="text-sm font-medium text-gray-500">Last Name</span>
          <span class="text-sm font-semibold text-gray-900"><%= user.lastName %></span>
        </div>
        
        <div class="flex justify-between items-center">
          <span class="text-sm font-medium text-gray-500">Email</span>
          <span class="text-sm font-semibold text-gray-900"><%= user.email %></span>
        </div>
      </div>

      <form action="/api/v1/logout" method="POST" class="pt-2">
        <button type="submit" class="w-full bg-red-50 text-red-600 hover:bg-red-100 hover:text-red-700 border border-red-200 font-medium py-2.5 px-4 rounded-lg transition-all duration-150 text-sm flex justify-center items-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75" />
          </svg>
          Logout
        </button>
      </form>
      
    </div>

    <script>
      window.addEventListener('DOMContentLoaded', () => {
        const successAlert = document.getElementById('success-alert');
        const errorAlert = document.getElementById('error-alert');

        // Alert ko fade out aur remove karne ka function
        const autoHide = (element) => {
          if (element) {
            setTimeout(() => {
              element.classList.add('opacity-0'); // Tailwind opacity zero transition triggers
              setTimeout(() => {
                element.remove(); // DOM se delete kar dega text container ko
              }, 500); // 0.5s fade effect ke liye delay
            }, 3000); // 3 seconds tak message dikhega
          }
        };

        autoHide(successAlert);
        autoHide(errorAlert);
      });
    </script>

  </body>
</html>